<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>MAC Tools – MSC Portal</title>
<link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;500;600;700;900&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --white:#fff;--grey-medium:#dbdeea;--grey-dark:#69757b;
  --blue-dark:#343945;--blue-medium:#3fa7fc;--green-dark:#149c48;
}
html,body{width:100%;height:100%;overflow:hidden;font-family:'Lato',sans-serif,system-ui;}
.page{position:relative;width:100%;height:100vh;overflow:hidden;background:linear-gradient(135deg,#c8dff5 0%,#deeeff 40%,#c5e8d8 100%);}
.bg-blur{position:absolute;inset:0;background:rgba(243,249,255,0.82);backdrop-filter:blur(7.5px);-webkit-backdrop-filter:blur(7.5px);z-index:1;}
.panel-wrap{position:absolute;right:54px;top:180px;z-index:10;width:350px;}
.login-card{background:rgba(255,255,255,0.93);border:1px solid var(--grey-medium);border-radius:8px;box-shadow:3px 3px 11px rgba(34,46,57,0.06);padding:20px;}
.login-header{display:flex;align-items:flex-start;gap:16px;margin-bottom:18px;}
.logo-box{flex-shrink:0;width:60px;height:60px;background:#fff;border:1px solid var(--grey-medium);border-radius:8px;display:flex;align-items:center;justify-content:center;}
.welcome-text{display:flex;flex-direction:column;gap:2px;padding-top:4px;}
.welcome-title{font-size:22px;font-weight:400;line-height:26px;color:var(--blue-dark);}
.welcome-name{font-size:16px;font-weight:700;color:var(--green-dark);}
.field-label{font-size:14px;color:var(--blue-dark);margin-bottom:6px;}
.pw-wrap{margin-bottom:10px;}
.pw-field{width:100%;height:36px;border:1px solid var(--grey-medium);border-radius:4px;background:#fff;padding:0 12px;font-size:14px;color:var(--blue-dark);outline:none;letter-spacing:3px;}
.pw-field:focus{border-color:var(--blue-medium);}
.links-row{display:flex;justify-content:space-between;margin-bottom:14px;}
.link-text{font-size:10px;color:var(--blue-dark);cursor:pointer;text-decoration:none;}
.link-text:hover{text-decoration:underline;}
.login-btn{width:100%;height:40px;background:var(--green-dark);border:none;border-radius:5px;color:#fff;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;transition:background 0.18s;}
.login-btn:hover{background:#118a3f;}
.tabs-card{background:transparent;margin-top:30px;}
.tabs-header{display:flex;position:relative;}
.tab{flex:1;height:39px;display:flex;align-items:center;justify-content:center;gap:6px;cursor:pointer;font-size:14px;font-weight:600;border:1px solid var(--grey-medium);position:relative;}
.tab-news{background:rgba(255,255,255,0.93);border-radius:4px 4px 0 0;color:var(--blue-dark);border-bottom:none;z-index:2;}
.tab-news::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:var(--blue-medium);border-radius:8px 8px 0 0;}
.tab-learning{background:rgba(251,251,253,0.93);border-radius:0 8px 0 0;color:var(--grey-dark);z-index:1;}
.tab-divider{position:absolute;left:50%;top:50%;transform:translateY(-50%);width:1px;height:36px;background:var(--grey-medium);z-index:3;}
.tab-body{background:rgba(255,255,255,0.93);border:1px solid var(--grey-medium);border-top:none;border-radius:0 0 8px 8px;padding:18px 20px 22px;}
.tab-body-text{font-size:12px;color:var(--blue-dark);line-height:1.6;margin-bottom:16px;}
.get-trained-btn{display:flex;align-items:center;justify-content:center;width:120px;height:40px;border:1px solid var(--grey-medium);border-radius:4px;background:#fff;color:var(--blue-medium);font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;}
.get-trained-btn:hover{background:#eef6ff;}

#cat-gif{
  position:fixed;
  z-index:999;
  pointer-events:none;
  width:500px;
  /* parked way off screen until JS kicks in */
  left:9999px;
  top:9999px;
}
#restart-btn{
  position:fixed;
  bottom:24px;
  left:50%;
  transform:translateX(-50%);
  z-index:1000;
  background:rgba(30,30,30,0.72);
  color:#fff;
  border:none;
  border-radius:20px;
  padding:8px 22px;
  font-size:13px;
  font-family:'Lato',sans-serif;
  cursor:pointer;
  letter-spacing:0.3px;
  transition:background 0.18s;
}
#restart-btn:hover{background:rgba(30,30,30,0.92);}
</style>
</head>
<body>
<div class="page">
  <div class="bg-blur"></div>

  <div class="panel-wrap">
    <div class="login-card">
      <div class="login-header">
        <div class="logo-box">
          <svg width="46" height="32" viewBox="0 0 46 32"><rect width="46" height="32" rx="4" fill="#149c48"/><text x="23" y="21" text-anchor="middle" fill="white" font-family="system-ui,sans-serif" font-size="12" font-weight="900">MAC</text></svg>
        </div>
        <div class="welcome-text">
          <span class="welcome-title">Welcome Back</span>
          <span class="welcome-name">Anne Marie Shea</span>
        </div>
      </div>
      <p class="field-label">Password</p>
      <div class="pw-wrap">
        <input class="pw-field" type="password" value="password" autocomplete="current-password"/>
      </div>
      <div class="links-row">
        <a class="link-text" href="#">Forgot Password?</a>
        <a class="link-text" href="#">Switch Accounts</a>
      </div>
      <button class="login-btn">Login</button>
    </div>

    <div class="tabs-card">
      <div class="tabs-header" style="position:relative;">
        <div class="tab tab-news">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="3" width="14" height="10" rx="2" stroke="#343945" stroke-width="1.1"/><line x1="4" y1="6.5" x2="12" y2="6.5" stroke="#343945" stroke-width="0.9"/><line x1="4" y1="9.5" x2="9" y2="9.5" stroke="#343945" stroke-width="0.9"/></svg>
          News
        </div>
        <div class="tab-divider"></div>
        <div class="tab tab-learning">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 3L14 6.5L8 10L2 6.5L8 3Z" stroke="#69757b" stroke-width="1.1"/><path d="M5 8.5V11.5C5 11.5 6.3 13 8 13s3-1.5 3-1.5V8.5" stroke="#69757b" stroke-width="1.1"/></svg>
          Learning
        </div>
      </div>
      <div class="tab-body">
        <p class="tab-body-text">All Webinars are Free! Sign up for one of our public sessions or feel free to request a private webinar. All at no cost. We also have other training available.</p>
        <button class="get-trained-btn">Get Trained</button>
      </div>
    </div>
  </div>

  <img id="cat-gif" alt="cat"/>
  <button id="restart-btn">↺ Restart animation</button>
</div>

<script>
(function(){
  const cat        = document.getElementById('cat-gif');
  const restartBtn = document.getElementById('restart-btn');
  const GIF_SRC    = 'https://raw.githubusercontent.com/denea-msc/mewologin/refs/heads/main/cat-Tail2.gif';
  const GIF_MS     = 2400; // GIF duration — freeze after this many ms from arrival
  const TRAVEL_MS  = 800;  // travel time in ms

  let animId    = null;
  let stopTimer = null;

  function getTarget(){
    const card = document.querySelector('.login-card');
    const r    = card.getBoundingClientRect();
    return {
      x: r.right - 460,
      y: r.top   - 120
    };
  }

  function freeze(){
    // Draw current frame to canvas, swap src to PNG — stops the loop
    const cvs = document.createElement('canvas');
    cvs.width  = cat.naturalWidth;
    cvs.height = cat.naturalHeight;
    try {
      cvs.getContext('2d').drawImage(cat, 0, 0);
      cat.src = cvs.toDataURL('image/png');
    } catch(e){
      // cross-origin: can't snapshot, just leave it (browser may loop but nothing we can do)
    }
  }

  function runAnimation(){
    // Clean up previous run
    if(animId)    { cancelAnimationFrame(animId); animId = null; }
    if(stopTimer) { clearTimeout(stopTimer);       stopTimer = null; }

    // Set fresh GIF src — cache-bust so it restarts from frame 1
    cat.src = GIF_SRC + '?v=' + Date.now();

    const target = getTarget();

    // True start: bottom-right corner, fully off screen
    const startX = window.innerWidth  + 20;
    const startY = window.innerHeight + 20;

    // Pre-position before first paint so it never flashes at (0,0) or wrong spot
    cat.style.left = startX + 'px';
    cat.style.top  = startY + 'px';

    let t0 = null;

    function move(ts){
      if(!t0) t0 = ts;
      const p    = Math.min((ts - t0) / TRAVEL_MS, 1);
      // ease-out cubic — fast start, smooth landing
      const ease = 1 - Math.pow(1 - p, 3);

      cat.style.left = (startX + (target.x - startX) * ease) + 'px';
      cat.style.top  = (startY + (target.y - startY) * ease) + 'px';

      if(p < 1){
        animId = requestAnimationFrame(move);
      } else {
        // Snap exactly to target
        cat.style.left = target.x + 'px';
        cat.style.top  = target.y + 'px';
        animId = null;
        // Freeze after one GIF cycle
        stopTimer = setTimeout(freeze, GIF_MS);
      }
    }

    // Wait one rAF to ensure src change has been applied before we start moving,
    // so there's no frame where it jumps from 9999 to startX/Y
    requestAnimationFrame(function(){
      requestAnimationFrame(function(){
        animId = requestAnimationFrame(move);
      });
    });
  }

  restartBtn.addEventListener('click', runAnimation);
  setTimeout(runAnimation, 300);
})();
</script>
</body>
</html>
